{
	"name": "DF_Silver_Limpieza_Catalogos",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_AsAlmacenes",
						"type": "DatasetReference"
					},

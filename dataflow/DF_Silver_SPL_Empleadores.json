{
	"name": "DF_Silver_SPL_Empleadores",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SplEmpleadores",
						"type": "DatasetReference"
					},
					"name": "OrigenBronceEmpleadores"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_SQL_Destino",
						"type": "LinkedServiceReference"
					},
					"name": "DestinoSilverSUPEmpleadores"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          empleador_id as string,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          nro_patronal as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> OrigenBronceEmpleadores",
				"OrigenBronceEmpleadores sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'silver',",
				"     tableName: 'spl_empleadores',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     recreate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> DestinoSilverSUPEmpleadores"
			]
		}
	}
}